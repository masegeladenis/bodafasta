RewriteEngine On

# Force a single canonical production host for crawlable URLs.
# Local development hosts are excluded so XAMPP remains usable.
RewriteCond %{HTTP_HOST} !^(localhost|127\.0\.0\.1)(:\d+)?$ [NC]
RewriteCond %{HTTP_HOST} !^\[::1\](:\d+)?$ [NC]
RewriteCond %{HTTP_HOST} ^www\.bodafasta\.co\.tz$ [NC]
RewriteRule ^ https://bodafasta.co.tz%{REQUEST_URI} [L,R=301]

# Redirect index to root
RewriteCond %{THE_REQUEST} \s/+index(?:\.php)?[\s?] [NC]
RewriteRule ^index(?:\.php)?$ / [L,R=301]

# Clean URLs: redirect .php → no extension
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^(.+)\.php$ /$1 [R=301,L]

# Remove trailing slashes from non-directory URLs.
RewriteCond %{REQUEST_URI} !^/$
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.+)/$ /$1 [R=301,L]

# Internal rewrite (no loop)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L,QSA]